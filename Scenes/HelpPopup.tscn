theme_override_font_sizes/font_size = 48
text = "ARCHITECT'S GUIDE"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="MarginContainer/VBoxContainer"]
layout_mode = 2

[node name="ScrollContainer" type="ScrollContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

[node name="ContentLabel" type="RichTextLabel" parent="MarginContainer/VBoxContainer/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_colors/default_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/normal_font_size = 32
theme_override_font_sizes/bold_font_size = 36
bbcode_enabled = true
text = "[b][color=#60fafc]FUSION PROTOCOLS[/color][/b]
Combine elements by adding their Atomic Numbers.
Hydrogen (1) + Helium (2) = Lithium (3).
Higher Stability parents yield better results.

[b][color=#60fafc]COMBAT DYNAMICS[/color][/b]
Speed determines turn order.
[color=#ffd700]Vanguard (Center)[/color] takes the most hits.
[color=#60fafc]Flanks (Sides)[/color] deal damage safely.
Use Class Synergies to gain an edge.

[b][color=#60fafc]CAMPAIGN[/color][/b]
Discovery Runs are rogue-lite expeditions.
Defeat waves to earn Binding Energy.
If you retreat, you keep your loot.
If you fall, you lose collected Energy.

[b][color=#60fafc]STABILITY & MASTERY[/color][/b]
Stability increases stats (up to +50%).
At 100% Stability, a unit gains [color=#ffd700]Mastery[/color], unlocking powerful passive effects."

[node name="CloseButton" type="Button" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 80)
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Close"
